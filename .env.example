# Copy this to .env for local development
# On Railway, set these in the Variables tab

# PostgreSQL connection string (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: comma-separated list of extra allowed CORS origins
ALLOWED_ORIGINS=https://www.seygo.it.com

# Node environment
NODE_ENV=production
